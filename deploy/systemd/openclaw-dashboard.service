[Unit]
Description=OpenClaw Multi-Agent Dashboard API
After=network-online.target openclaw-multiagent.service
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/openclaw-multi-agents
Environment=PYTHONUNBUFFERED=1
Environment=OPENCLAW_HEALTH_URL=http://127.0.0.1:8001/health
EnvironmentFile=-/etc/default/openclaw-multiagent
ExecStart=/usr/bin/python3 -m uvicorn dashboard_api:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=5
StartLimitIntervalSec=0
TimeoutStartSec=60
TimeoutStopSec=30
KillMode=process
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/www/openclaw-multi-agents

[Install]
WantedBy=multi-user.target
