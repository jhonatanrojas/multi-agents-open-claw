# ═══════════════════════════════════════════════════════════════════════════════
# OpenClaw Multi-Agent Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# 
# This file documents all environment variables used by the system.
# Copy this file to .env and fill in your values.
#
# Configuration is loaded by config.py at startup.
# Use `from config import config` to access values.
#
# ═══════════════════════════════════════════════════════════════════════════════

# ── Dashboard API Configuration ────────────────────────────────────────────────

# API key for dashboard authentication
# Set to empty string to disable authentication (development only)
# Example: DASHBOARD_API_KEY=your-secret-key-here
# 
# 🔑 DEFAULT LOGIN CREDENTIALS:
# Username: admin
# Password/API Key: dev-squad-api-key-2026
DASHBOARD_API_KEY=dev-squad-api-key-2026

# Admin credentials for web login (optional, falls back to API key)
# DASHBOARD_ADMIN_USER=admin
# DASHBOARD_ADMIN_PASSWORD=admin123

# CORS configuration (F0.4)
# Comma-separated list of allowed origins
# DO NOT use '*' in production when authentication is enabled
# Development: http://localhost:3000,http://localhost:5173
# Production: https://dashboard.yourdomain.com
DASHBOARD_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Session configuration (F0.1)
# Secret key for signing session cookies (auto-derived from API key if not set)
DASHBOARD_SESSION_SECRET=
# Maximum session age in seconds (default: 86400 = 24 hours)
DASHBOARD_SESSION_MAX_AGE=86400

# Server configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8001
DASHBOARD_WORKERS=1

# ── Model Fallback Configuration (F0.3) ─────────────────────────────────────────

# Path to model status cache file
MODEL_STATUS_CACHE_PATH=/var/cache/openclaw/model_status.json
# Cache TTL in seconds (default: 300 = 5 minutes)
MODEL_STATUS_CACHE_TTL=300

# ── Gateway Configuration ───────────────────────────────────────────────────────

# OpenClaw Gateway connection settings
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# ── Runtime Profile Configuration ──────────────────────────────────────────────

# OpenClaw runtime home directory
OPENCLAW_RUNTIME_HOME=/root/.openclaw-runtime
# Runtime profile name
OPENCLAW_PROFILE=multi-agents-runtime-v2
# Runtime state directory
OPENCLAW_RUNTIME_DIR=/root/.openclaw/multi-agents

# ── Telegram Notifications ─────────────────────────────────────────────────────

# Telegram bot token for notifications (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Chat ID to send notifications to
TELEGRAM_CHAT_ID=

# ── Git Identity ────────────────────────────────────────────────────────────────

# Git identity for automated commits
GIT_AUTHOR_NAME=OpenClaw
GIT_AUTHOR_EMAIL=openclaw@example.com
GIT_COMMITTER_NAME=OpenClaw
GIT_COMMITTER_EMAIL=openclaw@example.com

# ── Miniverse / Preview Integrations ───────────────────────────────────────────

# Enable Miniverse integration
MINIVERSE_ENABLED=false
# Miniverse server URL
MINIVERSE_URL=http://127.0.0.1:9999
# Miniverse UI URL (for previews)
MINIVERSE_UI_URL=http://127.0.0.1:9999
# Request timeout in seconds
MINIVERSE_REQUEST_TIMEOUT_SEC=6
# Cache TTL in seconds
MINIVERSE_CACHE_TTL_SEC=300

# ── Provider API Keys (optional) ───────────────────────────────────────────────

# Fireworks AI
FIREWORKS_API_KEY=
# Groq
GROQ_API_KEY=
# NVIDIA NIM
NVIDIA_API_KEY=
# Blink (OpenClaw API)
BLINK_API_KEY=
# OpenClaw GitHub integration
OPENCLAW_GITHUB_TOKEN=
# GitHub (general)
GITHUB_TOKEN=

# ── Test Configuration ─────────────────────────────────────────────────────────

# Base URL for API tests
TEST_API_URL=http://127.0.0.1:8001
