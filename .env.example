# OpenClaw Multi-Agent Environment

# API key for the dashboard and internal API
DASHBOARD_API_KEY=dev-squad-api-key-2026

# Gateway auth
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_HOST=127.0.0.1
OPENCLAW_GATEWAY_PORT=18789

# Runtime profile
OPENCLAW_RUNTIME_HOME=/root/.openclaw-runtime
OPENCLAW_PROFILE=multi-agents-runtime-v2
OPENCLAW_RUNTIME_DIR=/root/.openclaw/multi-agents

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Git identity for automated commits
GIT_AUTHOR_NAME=OpenClaw
GIT_AUTHOR_EMAIL=openclaw@example.com
GIT_COMMITTER_NAME=OpenClaw
GIT_COMMITTER_EMAIL=openclaw@example.com

# Miniverse / preview integrations
MINIVERSE_ENABLED=false
MINIVERSE_URL=http://127.0.0.1:9999
MINIVERSE_UI_URL=http://127.0.0.1:9999
MINIVERSE_REQUEST_TIMEOUT_SEC=6
MINIVERSE_CACHE_TTL_SEC=300

# Optional provider tokens
FIREWORKS_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=
BLINK_API_KEY=
OPENCLAW_GITHUB_TOKEN=
GITHUB_TOKEN=
