# ── Dev Squad — Environment Variables ──────────────────────────────────────────
# Copy to .env and fill in your values.

# ── Dashboard auth (GAP-1 / P5) ───────────────────────────────────────────────
# Set an API key to protect all dashboard endpoints.
# Provide this value in the X-API-Key request header.
# Leave empty to disable auth (development only).
DASHBOARD_API_KEY=dev-squad-api-key-2026

# ── Telegram notifications ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Miniverse world ───────────────────────────────────────────────────────────
# Default: public cloud world.  Use http://localhost:4321 after npx create-miniverse
MINIVERSE_URL=https://miniverse-public-production.up.railway.app

# ── Git identity ──────────────────────────────────────────────────────────────
GIT_AUTHOR_NAME=OpenClaw
GIT_AUTHOR_EMAIL=openclaw@example.com

# ── Model overrides (GAP-5 / P6) ─────────────────────────────────────────────
# These take precedence over gateway.yml when set.
# Use PUT /api/models to change at runtime without restart.
ARCH_MODEL=nvidia/z-ai/glm5
BYTE_MODEL=nvidia/moonshotai/kimi-k2.5
BYTE_MODEL_FALLBACK=deepseek/deepseek-chat
PIXEL_MODEL=deepseek/deepseek-chat
