[Unit]
Description=OpenClaw Multi-Agent Orchestrator
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/openclaw-multi-agents
Environment=PYTHONUNBUFFERED=1
Environment=OPENCLAW_HEALTH_URL=http://127.0.0.1:8080/health
EnvironmentFile=-/etc/default/openclaw-multiagent
ExecStart=/usr/bin/python3 /var/www/openclaw-multi-agents/orchestrator.py --task-timeout-sec 1800 --phase-timeout-sec 7200 --retry-attempts 3 --retry-delay-sec 2
Restart=always
RestartSec=5
StartLimitIntervalSec=0
TimeoutStartSec=60
TimeoutStopSec=30
KillMode=process
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/www/openclaw-multi-agents

[Install]
WantedBy=multi-user.target
